# ===========================
# NeuralDB Environment Variables
# ===========================
# Copy to .env and fill in values
# NEVER commit .env to Git

# ===========================
# Application
# ===========================
APP_NAME=neuraldb
APP_ENV=development                    # development | staging | production
APP_DEBUG=true
APP_PORT=8000
APP_SECRET_KEY=change-me-to-random-64-chars
APP_CORS_ORIGINS=http://localhost:3000

# ===========================
# Database (System PostgreSQL 16)
# ===========================
DATABASE_URL=postgresql+asyncpg://neuraldb:password@localhost:5432/neuraldb
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false                    # true = SQL 로깅

# ===========================
# Valkey (Cache)
# ===========================
VALKEY_URL=redis://localhost:6379/0     # 프로토콜은 redis:// (Valkey 호환)
VALKEY_TTL_DEFAULT=3600

# ===========================
# Kafka (Messaging)
# ===========================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=neuraldb-consumers

# ===========================
# Celery (Task Queue)
# ===========================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===========================
# AI/LLM Configuration
# ===========================
AI_MODE=online                         # online | offline

# Online Mode (Cloud LLM)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Offline Mode (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
VLLM_BASE_URL=http://localhost:8001
VLLM_MODEL=mistral-7b-instruct

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384                # 384 for MiniLM, 1536 for OpenAI

# ===========================
# Authentication
# ===========================
JWT_SECRET_KEY=change-me-jwt-secret-64-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# SSO/OIDC (Optional)
SSO_ENABLED=false
SSO_PROVIDER=                          # saml | oidc | ldap
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_ISSUER_URL=

# LDAP (Optional)
LDAP_SERVER=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# ===========================
# Notifications
# ===========================
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=neuraldb@example.com

PAGERDUTY_API_KEY=

# ===========================
# Monitoring (Self)
# ===========================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=neuraldb-backend
PROMETHEUS_ENABLED=true

# ===========================
# Autonomy
# ===========================
DEFAULT_AUTONOMY_LEVEL=1               # 0=alert-only, 1=suggest, 2=approved, 3=auto, 4=full
MAX_AUTONOMY_LEVEL=3                   # 시스템 최대 허용 등급

# ===========================
# Frontend (Vite)
# ===========================
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=http://localhost:8000/ws
VITE_APP_TITLE=NeuralDB
